{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipor",
  "version": "0.1.0",
  "identifier": "dev.infinith4.clipor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": ["msi", "nsis"],
    "windows": {
      "digestAlgorithm": "sha256",
      "signCommand": "echo %1"
    }
  }
}
